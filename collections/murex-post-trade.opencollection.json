              },
              {
                "name": "status",
                "value": "",
                "type": "query",
                "description": "Filter by margin call status"
              },
              {
                "name": "asOfDate",
                "value": "",
                "type": "query",
                "description": "Margin call date"
              },
              {
                "name": "limit",
