              }
            ]
          },
          "docs": "Retrieve CSA and collateral agreements with margin call status."
        },
        {
          "info": {
            "name": "Murex List margin calls",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.murex.com/v1/posttrade/collateral/margin-calls",
            "params": [
              {
                "name": "agreementId",
                "value": "",
